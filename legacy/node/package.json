{
  "name": "stripe-installer",
  "version": "0.6.0",
  "description": "AI-assisted Stripe setup with secure secret isolation",
  "type": "module",
  "main": "dist/gui/main.js",
  "bin": {
    "stripe-installer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "gui": "npm run build && electron .",
    "burn-test": "npm run build && node scripts/burn-test.mjs",
    "scan": "tsx src/cli.ts scan",
    "setup": "tsx src/cli.ts setup"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "ora": "^8.2.0",
    "pg": "^8.14.1",
    "stripe": "^17.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "electron": "^35.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
