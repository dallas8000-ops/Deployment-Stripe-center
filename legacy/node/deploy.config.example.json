{
  "domain": "app.yourdomain.com",
  "productionUrl": "https://app.yourdomain.com",
  "platform": "vercel",
  "postgres": {
    "provider": "neon",
    "connectionEnvVar": "DATABASE_URL",
    "autoProvision": false,
    "region": "aws-us-east-1",
    "projectName": "my-saas-app"
  },
  "monitoring": {
    "healthCheck": true,
    "sentry": false
  },
  "backup": {
    "enabled": true,
    "retentionDays": 14
  },
  "ssl": {
    "auto": true
  }
}
