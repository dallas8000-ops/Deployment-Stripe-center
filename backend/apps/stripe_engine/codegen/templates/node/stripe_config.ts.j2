/** Stripe price IDs from manifest — generated by Stripe Installer */
export const STRIPE_TIERS = [
[% for t in tiers %)
  { key: "[[ t.key ]]", tier: "[[ t.tier ]]", priceId: "[[ t.price_id ]]", label: "[[ t.label ]]" },
[% endfor %)
] as const;

export function getPriceId(tierKey: string): string | undefined {
  return STRIPE_TIERS.find((t) => t.key === tierKey)?.priceId;
}
