<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><title>Account</title></head>
<body style="font-family:system-ui;max-width:480px;margin:2rem auto">
  <h1>Account</h1>
  <p>Enter your Stripe customer ID to manage billing.</p>
  <input id="customerId" placeholder="cus_..." />
  <button onclick="openPortal()">Manage subscription</button>
  <script>
    const appUrl = "[[ app_url ]]";
    async function openPortal() {
      const customerId = document.getElementById("customerId").value;
      const res = await fetch(appUrl + "/stripe/portal", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ customerId }),
      });
      const data = await res.json();
      if (data.url) window.location.href = data.url;
    }
  </script>
</body>
</html>
