<script lang="ts">
  import { onMount } from "svelte";
  const tiers = [[ tiers | tojson ]];

  async function checkout(priceId: string) {
    const res = await fetch("/api/stripe/checkout", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ priceId }),
    });
    const data = await res.json();
    if (data.url) window.location.href = data.url;
  }

  let container: HTMLElement;
  onMount(() => {
    container.innerHTML = tiers
      .map(
        (t: { tier: string; label: string; price_id: string }) =>
          `<article><h2>${t.tier}</h2><p>${t.label}</p><button data-price="${t.price_id}">Subscribe</button></article>`
      )
      .join("");
    container.querySelectorAll("button").forEach((btn) => {
      btn.addEventListener("click", () => checkout(btn.getAttribute("data-price")!));
    });
  });
</script>

<main>
  <h1>Choose your plan</h1>
  <div bind:this={container}></div>
</main>
