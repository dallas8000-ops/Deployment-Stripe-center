<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><title>Pricing</title></head>
<body style="font-family:system-ui;max-width:960px;margin:0 auto;padding:2rem">
  <h1>Choose your plan</h1>
  <div style="display:grid;gap:1.5rem;grid-template-columns:repeat(auto-fit,minmax(240px,1fr))">
{% for t in tiers %}
    <article style="border:1px solid #e5e7eb;border-radius:12px;padding:1.5rem">
      <h2>{{ t.tier }}</h2>
      <p>{{ t.label }}</p>
      <form method="post" action="/stripe/checkout">
        <input type="hidden" name="priceId" value="{{ t.price_id }}" />
        <button type="submit">Subscribe</button>
      </form>
    </article>
{% endfor %}
  </div>
</body>
</html>
