VAULT_MASTER_KEY=
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis (broker + Channels). Start: docker compose up -d redis
REDIS_URL=redis://127.0.0.1:6379/0

# Dev shortcuts — no Celery worker or Redis required:
CELERY_EAGER=true
CHANNEL_LAYER_INMEMORY=true

# Production: set CELERY_EAGER=false, CHANNEL_LAYER_INMEMORY=false, run Celery + Daphne

# Optional path to Node stripe-installer CLI (pipeline can use Python codegen without this)
# STRIPE_INSTALLER_CLI=C:\path\to\Stripe Installer\dist\cli.js

# Platform billing (Stripe Installer SaaS subscriptions — optional for local dev)
# SAAS_STRIPE_SECRET_KEY=sk_test_...
# SAAS_STRIPE_WEBHOOK_SECRET=whsec_...
# SAAS_STRIPE_PRICE_STARTER=price_...
# SAAS_STRIPE_PRICE_PRO=price_...
# SAAS_STRIPE_PRICE_ENTERPRISE=price_...
# SAAS_BILLING_RETURN_URL=http://localhost:5173/billing

# Production database (optional — defaults to SQLite)
# DATABASE_URL=postgres://stripe_installer:stripe_installer@127.0.0.1:5432/stripe_installer
