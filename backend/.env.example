# Vault master key: local dev → ~/.stripe-installer/vault-master-key (never commit).
# Railway/production: set VAULT_MASTER_KEY in dashboard (64 hex chars). See docs/RAILWAY.md.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175

# Redis (broker + Channels). Start: docker compose up -d redis
REDIS_URL=redis://127.0.0.1:6379/0

# Dev shortcuts — no Celery worker or Redis required:
CELERY_EAGER=true
CHANNEL_LAYER_INMEMORY=true

# Single-container Railway (legacy): set true only when NOT using Redis + worker/beat split.
# ALLOW_SINGLE_CONTAINER=false

# Celery Beat runs catalog drift checks every 6 hours (stripe_engine.check_all_projects_drift)

# Optional path to archived Node CLI (legacy/node — Python codegen works without this)
# STRIPE_INSTALLER_CLI=C:\path\to\Stripe Installer\legacy\node\dist\cli.js

# Platform billing (Stripe Installer SaaS subscriptions — optional for local dev)
# SAAS_STRIPE_SECRET_KEY=sk_test_...
# SAAS_STRIPE_WEBHOOK_SECRET=whsec_...
# SAAS_STRIPE_PRICE_STARTER=price_...
# SAAS_STRIPE_PRICE_PRO=price_...
# SAAS_STRIPE_PRICE_ENTERPRISE=price_...
# SAAS_BILLING_RETURN_URL=http://localhost:5173/billing
# APP_PUBLIC_URL=http://localhost:5173

# Org email invites (console backend in dev — prints to terminal)
# INVITE_EMAIL_ENABLED=true
# ORG_INVITE_EXPIRY_DAYS=14
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Production database (optional — defaults to SQLite)
# DATABASE_URL=postgres://stripe_core:stripe_core@127.0.0.1:5432/stripe_core

# Git clone workspace (default: backend/clones/{project-slug})
# PROJECT_CLONE_ROOT=C:\path\to\clones

# GitHub App (optional — org-linked installations, PR readiness checks)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_APP_SLUG=your-github-app-slug
# GITHUB_APP_SETUP_URL=http://localhost:5173/agency/github/callback
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# Webhook URL: https://your-host/api/v1/webhooks/github/
# ORG_FREE_MEMBER_LIMIT=3
# ORG_FREE_PROJECT_LIMIT=5

# Software protection (deployed instances validate against this server)
# Dev: python manage.py issue_dev_license --email you@test.com --domain localhost
# LICENSE_ENFORCEMENT_ENABLED=false
# LICENSE_ENFORCEMENT_MODE=readonly
# LICENSE_READ_ONLY_MESSAGE=License invalid - running in read-only mode
# LICENSE_EMAIL_ENABLED=true
# STRIPE_INSTALLER_LICENSE_KEY=
# STRIPE_INSTALLER_DOMAIN=
# STRIPE_INSTALLER_VALIDATION_SERVER=https://your-licensing-server.example.com
# GITHUB_TOKEN=ghp_...          # or store GITHUB_TOKEN in project vault
# GIT_SSH_KEY_PATH=C:\Users\you\.ssh\id_ed25519
# GIT_CREDENTIALS_PATH=C:\Users\you\.git-credentials

# Railway (set in Railway dashboard Variables — see docs/RAILWAY.md)
# DATABASE_URL=          # from PostgreSQL plugin
# RAILWAY_PUBLIC_DOMAIN= # auto-injected by Railway
# APP_PUBLIC_URL=        # optional custom domain override
# SAAS_BILLING_RETURN_URL=https://your-app.up.railway.app/billing
# DJANGO_DEBUG=false

# MFA issuer shown in authenticator apps
# MFA_ISSUER_NAME=Automation Center

# Enterprise OIDC SSO (Okta, Azure AD, Google Workspace)
# OIDC_SSO_ENABLED=true
# OIDC_ISSUER_URL=https://your-tenant.okta.com/oauth2/default
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://your-app.up.railway.app/api/v1/auth/sso/callback/
# OIDC_ALLOWED_EMAIL_DOMAINS=yourcompany.com

# Observability (Phase 3)
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# LOG_LEVEL=INFO
