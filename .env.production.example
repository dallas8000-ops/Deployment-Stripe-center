NODE_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=stripe-installer-production.up.railway.app
APP_PUBLIC_URL=https://stripe-installer-production.up.railway.app
CORS_ALLOWED_ORIGINS=https://stripe-installer-production.up.railway.app
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
REDIS_URL=redis://default:password@host:6379/0
CELERY_EAGER=false
CHANNEL_LAYER_INMEMORY=false
VAULT_MASTER_KEY=replace-with-64-hex-characters

# Prefer a restricted Stripe key (rk_live_) with only the permissions this service uses.
SAAS_STRIPE_SECRET_KEY=rk_live_
SAAS_STRIPE_WEBHOOK_SECRET=whsec_
SAAS_STRIPE_PRICE_STARTER=price_
SAAS_STRIPE_PRICE_PRO=price_
SAAS_STRIPE_PRICE_ENTERPRISE=price_
SAAS_BILLING_RETURN_URL=https://stripe-installer-production.up.railway.app
STRIPE_API_VERSION=2026-05-27.dahlia

# Optional GitHub App integration.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
